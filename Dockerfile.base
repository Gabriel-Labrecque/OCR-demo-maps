FROM python:3.12-slim

ARG UID=1000
RUN useradd -m -u ${UID} appuser

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Shared heavy dependencies
RUN pip install --no-cache-dir \
    torch

RUN pip install --no-cache-dir \
    Pillow \
    numpy \
    accelerate \
    celery \
    redis \
    scikit-image

ENV HF_HOME=/app/models
RUN mkdir -p /app/models/hub && chown appuser:appuser /app/models/hub
VOLUME ["/app/models"]
