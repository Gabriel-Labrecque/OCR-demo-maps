# ── Shared ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
HF_HOME=/app/models

# ── Florence worker ──────────────────────────────────────────────────────────
# Directory where florence saves intermediate JSON before handing off to qwen
INTERMEDIATE_DIR=/data/intermediate
# Suffix appended to the base image name for florence's intermediate output
# e.g. "mymap" → "mymap-florence-ocr.json"
FLORENCE_OUTPUT_SUFFIX=-florence-ocr

# ── Qwen worker ──────────────────────────────────────────────────────────────
# Directory where qwen saves the final cleaned output
OUTPUT_DIR=/data/result
# Suffix appended to the base image name for qwen's final output
# e.g. "mymap" → "mymap-qwen-cleaned.json"
QWEN_OUTPUT_SUFFIX=-qwen-cleaned
