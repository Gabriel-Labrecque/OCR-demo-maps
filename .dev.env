# ── Shared ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
HF_HOME=/app/models

# ── Florence worker ──────────────────────────────────────────────────────────
INPUT_DIR=/data/input

# Directory where florence saves intermediate JSON before handing off to qwen
INTERMEDIATE_DIR=/data/intermediate
FLORENCE_OUTPUT_SUFFIX=-florence

# ── Qwen worker ──────────────────────────────────────────────────────────────
# Directory where qwen saves the final cleaned output
OUTPUT_DIR=/data/result
QWEN_OUTPUT_SUFFIX=-qwen

# Enable printing from containers without buffering (important for logs to appear in real time)
PYTHONUNBUFFERED=1
